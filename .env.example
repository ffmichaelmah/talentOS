# Copy to .env for local development, and set the same values in Vercel
# (Project → Settings → Environment Variables).

# Postgres connection string.
# - Neon: copy the connection string from the Neon dashboard.
# - Vercel Postgres: use the POSTGRES_PRISMA_URL it provides.
# Use the NON-pooled / direct URL so `prisma db push` works during build.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# Secret used to sign session cookies. Generate one with:
#   openssl rand -base64 32
AUTH_SECRET="change-me-to-a-long-random-string"
